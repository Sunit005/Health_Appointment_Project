# ============================================================
# Healthcare Appointment & Follow-up Manager — Environment Variables
# Copy this file to backend/.env and fill in real values.
# NEVER commit .env files to version control.
# ============================================================

# ── Server ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── Database (MySQL) ──────────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://healthcare_user:your_db_password@localhost:3306/healthcare_db

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT Secrets (generate with: openssl rand -hex 32) ─────────
JWT_ACCESS_SECRET=replace_with_32_plus_char_secret_access
JWT_REFRESH_SECRET=replace_with_32_plus_char_secret_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── MFA ───────────────────────────────────────────────────────
MFA_APP_NAME=Healthcare Manager

# ── Email (SendGrid) ──────────────────────────────────────────
# Get API key from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your_sendgrid_api_key
EMAIL_FROM_ADDRESS=no-reply@yourdomain.com

# ── AI (OpenAI) ───────────────────────────────────────────────
# Get from https://platform.openai.com/api-keys
# Leave blank to disable AI features (app works without it)
OPENAI_API_KEY=sk-your_openai_api_key
GEMINI_API_KEY=

# ── Google Calendar OAuth2 ────────────────────────────────────
# Create OAuth credentials at https://console.cloud.google.com/
# Enable Calendar API and create OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/v1/calendar/callback
GOOGLE_WEBHOOK_SECRET=your_webhook_verification_secret

# ── Frontend (Vite) ──────────────────────────────────────────
# These go in frontend/.env
VITE_API_URL=http://localhost:5000
VITE_APP_NAME=Healthcare Manager
