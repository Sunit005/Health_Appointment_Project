# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database (MySQL)
DATABASE_URL=mysql://healthcare_user:user_password_123@localhost:3306/healthcare_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=generate_a_secure_long_secret_for_access_tokens_min_32_chars
JWT_REFRESH_SECRET=generate_a_secure_long_secret_for_refresh_tokens_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# MFA
MFA_APP_NAME=Healthcare Manager

# Email (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM_ADDRESS=no-reply@healthcaremanager.com

# AI (leave blank to disable gracefully)
OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=

# Google Calendar OAuth2 (leave blank to disable gracefully)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/v1/calendar/callback
GOOGLE_WEBHOOK_SECRET=your-google-webhook-verification-secret
