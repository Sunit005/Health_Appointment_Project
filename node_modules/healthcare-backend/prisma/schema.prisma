datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum AppointmentStatus {
  PENDING_HOLD   // 5-minute slot hold, not yet confirmed
  BOOKED
  COMPLETED
  CANCELLED
  NOSHOW
  RESCHEDULED
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  EMAIL
  SMS
  PUSH
}

enum CalendarSyncStatus {
  IN_SYNC
  PENDING
  FAILED
}

enum UrgencyLevel {
  ROUTINE
  URGENT
  CRITICAL
}

// ---------------------------------------------------------------------------
// Core Identity & Session Domain
// ---------------------------------------------------------------------------

model User {
  id                        String    @id @default(uuid())
  email                     String    @unique
  passwordHash              String    @map("password_hash")
  role                      Role
  isEmailVerified           Boolean   @default(false) @map("is_email_verified")
  emailVerifyToken          String?   @map("email_verify_token") @db.VarChar(512)
  emailVerifyTokenExpires   DateTime? @map("email_verify_token_expires")
  passwordResetToken        String?   @map("password_reset_token") @db.VarChar(512)
  passwordResetTokenExpires DateTime? @map("password_reset_token_expires")
  mfaSecret                 String?   @map("mfa_secret") @db.VarChar(512)
  mfaEnabled                Boolean   @default(false) @map("mfa_enabled")
  lastLoginAt               DateTime? @map("last_login_at")
  createdAt                 DateTime  @default(now()) @map("created_at")
  updatedAt                 DateTime  @updatedAt @map("updated_at")
  deletedAt                 DateTime? @map("deleted_at")
  isDeleted                 Boolean   @default(false) @map("is_deleted")

  sessions      Session[]
  refreshTokens RefreshToken[]
  doctor        Doctor?
  patient       Patient?
  auditLogs     AuditLog[]

  @@index([email])
  @@index([passwordResetToken])
  @@index([emailVerifyToken])
  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  userAgent String?  @map("user_agent") @db.Text
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  isActive  Boolean  @default(true) @map("is_active")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@index([userId])
  @@index([isActive])
  @@map("sessions")
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique @map("token_hash") @db.VarChar(512)
  userId    String   @map("user_id")
  sessionId String   @map("session_id")
  familyId  String   @map("family_id") @db.VarChar(64)
  isUsed    Boolean  @default(false) @map("is_used")
  isRevoked Boolean  @default(false) @map("is_revoked")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

// ---------------------------------------------------------------------------
// Profile Domain
// ---------------------------------------------------------------------------

model Doctor {
  id                   String   @id @default(uuid())
  userId               String   @unique @map("user_id")
  firstName            String   @map("first_name") @db.VarChar(100)
  lastName             String   @map("last_name") @db.VarChar(100)
  specialty            String   @db.VarChar(150)
  licenseNumber        String?  @unique @map("license_number") @db.VarChar(50)
  bio                  String?  @db.Text
  avatarUrl            String?  @map("avatar_url") @db.VarChar(512)
  rating               Float    @default(0.0)
  reviewCount          Int      @default(0) @map("review_count")
  isAvailable          Boolean  @default(true) @map("is_available")
  slotDurationMinutes  Int      @default(30) @map("slot_duration_minutes")
  googleCalendarToken  String?  @map("google_calendar_token") @db.Text
  googleRefreshToken   String?  @map("google_refresh_token") @db.Text
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  isDeleted            Boolean  @default(false) @map("is_deleted")
  deletedAt            DateTime? @map("deleted_at")

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  workingHours DoctorWorkingHour[]
  leaves       DoctorLeave[]

  @@index([specialty])
  @@index([isAvailable])
  @@index([isDeleted])
  @@map("doctors")
}

model Patient {
  id                  String    @id @default(uuid())
  userId              String    @unique @map("user_id")
  firstName           String    @map("first_name") @db.VarChar(100)
  lastName            String    @map("last_name") @db.VarChar(100)
  dob                 DateTime  @map("date_of_birth") @db.Date
  phoneNumber         String?   @map("phone_number") @db.VarChar(20)
  avatarUrl           String?   @map("avatar_url") @db.VarChar(512)
  medicalRecordNumber String    @unique @default(uuid()) @map("medical_record_number") @db.VarChar(50)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  isDeleted           Boolean   @default(false) @map("is_deleted")
  deletedAt           DateTime? @map("deleted_at")

  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments      Appointment[]
  prescriptions     Prescription[]
  medicationReminders MedicationReminder[]
  notifications     Notification[]

  @@index([userId])
  @@index([isDeleted])
  @@map("patients")
}

// ---------------------------------------------------------------------------
// Schedule Domain
// ---------------------------------------------------------------------------

model DoctorWorkingHour {
  id                  String   @id @default(uuid())
  doctorId            String   @map("doctor_id")
  dayOfWeek           Int      @map("day_of_week") // 0=Sunday, 6=Saturday
  startTime           String   @map("start_time") @db.VarChar(5)  // "09:00"
  endTime             String   @map("end_time") @db.VarChar(5)    // "17:00"
  slotDurationMinutes Int      @default(30) @map("slot_duration_minutes")
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, dayOfWeek, startTime], name: "uq_doctor_day_start")
  @@index([doctorId])
  @@map("doctor_working_hours")
}

model DoctorLeave {
  id        String      @id @default(uuid())
  doctorId  String      @map("doctor_id")
  startDate DateTime    @map("start_date")
  endDate   DateTime    @map("end_date")
  reason    String?     @db.Text
  status    LeaveStatus @default(PENDING)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([startDate])
  @@map("doctor_leaves")
}

// ---------------------------------------------------------------------------
// Appointment Domain
// ---------------------------------------------------------------------------

model Appointment {
  id             String            @id @default(uuid())
  doctorId       String            @map("doctor_id")
  patientId      String            @map("patient_id")
  scheduledStart DateTime          @map("scheduled_start")
  scheduledEnd   DateTime          @map("scheduled_end")
  status         AppointmentStatus @default(BOOKED)
  notes          String?           @db.Text
  holdExpiresAt  DateTime?         @map("hold_expires_at")  // 5-minute hold TTL
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  cancelledAt    DateTime?         @map("cancelled_at")
  cancelReason   String?           @map("cancel_reason") @db.Text

  active         String?           @map("active") @db.VarChar(10)

  doctor            Doctor              @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  patient           Patient             @relation(fields: [patientId], references: [id], onDelete: Restrict)
  symptomSubmission SymptomSubmission?
  preVisitSummary   PreVisitSummary?
  visitNote         VisitNote?
  prescriptions     Prescription[]
  calendarEvent     CalendarEvent?

  // Unique constraint prevents double-booking the same doctor slot
  @@unique([doctorId, scheduledStart, active], name: "uq_doctor_slot")
  @@index([doctorId, scheduledStart])
  @@index([patientId])
  @@index([status])
  @@map("appointments")
}

// ---------------------------------------------------------------------------
// AI & Clinical Domain
// ---------------------------------------------------------------------------

model SymptomSubmission {
  id             String       @id @default(uuid())
  appointmentId  String       @unique @map("appointment_id")
  rawText        String       @map("raw_text") @db.Text
  parsedSymptoms Json?        @map("parsed_symptoms")
  urgencyLevel   UrgencyLevel @default(ROUTINE) @map("urgency_level")
  chiefComplaint String?      @map("chief_complaint") @db.Text
  suggestedQuestions Json?    @map("suggested_questions")  // LLM-generated questions
  llmProcessed   Boolean      @default(false) @map("llm_processed")
  createdAt      DateTime     @default(now()) @map("created_at")

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@map("symptom_submissions")
}

model PreVisitSummary {
  id            String   @id @default(uuid())
  appointmentId String   @unique @map("appointment_id")
  summary       String   @db.Text
  urgencyLevel  UrgencyLevel @map("urgency_level")
  rawPrompt     String?  @map("raw_prompt") @db.Text
  generatedAt   DateTime @default(now()) @map("generated_at")

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@map("pre_visit_summaries")
}

model VisitNote {
  id              String   @id @default(uuid())
  appointmentId   String   @unique @map("appointment_id")
  doctorNotes     String   @map("doctor_notes") @db.Text
  diagnosis       String?  @db.Text
  patientSummary  String?  @map("patient_summary") @db.Text  // LLM-generated patient-friendly
  glossaryMappings Json?   @map("glossary_mappings")
  llmProcessed    Boolean  @default(false) @map("llm_processed")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@map("visit_notes")
}

// ---------------------------------------------------------------------------
// Prescription & Medication Domain
// ---------------------------------------------------------------------------

model Prescription {
  id            String   @id @default(uuid())
  appointmentId String   @map("appointment_id")
  patientId     String   @map("patient_id")
  clinicalNotes String?  @map("clinical_notes") @db.Text
  prescribedAt  DateTime @default(now()) @map("prescribed_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  appointment         Appointment          @relation(fields: [appointmentId], references: [id], onDelete: Restrict)
  patient             Patient              @relation(fields: [patientId], references: [id], onDelete: Restrict)
  medicationReminders MedicationReminder[]

  @@index([patientId])
  @@index([appointmentId])
  @@map("prescriptions")
}

model MedicationReminder {
  id               String   @id @default(uuid())
  prescriptionId   String   @map("prescription_id")
  patientId        String   @map("patient_id")
  medicationName   String   @map("medication_name") @db.VarChar(255)
  dosageInstruction String  @map("dosage_instruction") @db.VarChar(255)
  frequencyCron    String   @map("frequency_cron") @db.VarChar(50)
  isActive         Boolean  @default(true) @map("is_active")
  nextFireAt       DateTime? @map("next_fire_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  logs         MedicationReminderLog[]

  @@index([patientId])
  @@index([isActive, nextFireAt])
  @@map("medication_reminders")
}

model MedicationReminderLog {
  id                   String             @id @default(uuid())
  medicationReminderId String             @map("medication_reminder_id")
  scheduledTime        DateTime           @map("scheduled_time")
  takenAt              DateTime?          @map("taken_at")
  status               String             @default("PENDING") @db.VarChar(20) // PENDING, COMPLETED, MISSED
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  medicationReminder MedicationReminder @relation(fields: [medicationReminderId], references: [id], onDelete: Cascade)

  @@index([medicationReminderId])
  @@map("medication_reminder_logs")
}

// ---------------------------------------------------------------------------
// Notification Domain
// ---------------------------------------------------------------------------

model Notification {
  id           String           @id @default(uuid())
  patientId    String           @map("patient_id")
  type         NotificationType
  subject      String           @db.VarChar(255)
  body         String           @db.Text
  isRead       Boolean          @default(false) @map("is_read")
  dispatchedAt DateTime         @default(now()) @map("dispatched_at")
  metadata     Json?

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([isRead])
  @@map("notifications")
}

// ---------------------------------------------------------------------------
// Calendar Integration Domain
// ---------------------------------------------------------------------------

model CalendarEvent {
  id             String             @id @default(uuid())
  appointmentId  String             @unique @map("appointment_id")
  googleEventId  String?            @unique @map("google_event_id") @db.VarChar(255)
  syncStatus     CalendarSyncStatus @default(PENDING) @map("sync_status")
  lastSyncedAt   DateTime?          @map("last_synced_at")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([googleEventId])
  @@index([syncStatus])
  @@map("calendar_events")
}

// ---------------------------------------------------------------------------
// Audit Logs
// ---------------------------------------------------------------------------

model AuditLog {
  id             String   @id @default(uuid())
  userId         String?  @map("user_id")
  action         String   @db.VarChar(100)
  resourceType   String   @map("resource_type") @db.VarChar(100)
  resourceId     String?  @map("resource_id") @db.VarChar(64)
  ipAddress      String?  @map("ip_address") @db.VarChar(45)
  correlationId  String?  @map("correlation_id") @db.VarChar(64)
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([resourceType, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}
