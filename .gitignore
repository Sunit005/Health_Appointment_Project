# =============================================================
# Healthcare Appointment Manager — .gitignore
# =============================================================

# -------------------------------------------------------
# Dependencies
# -------------------------------------------------------
node_modules/
**/node_modules/

# -------------------------------------------------------
# Build outputs
# -------------------------------------------------------
dist/
build/
**/dist/
**/build/

# TypeScript compiled output (backend)
backend/src/**/*.js
backend/src/**/*.js.map
backend/src/**/*.d.ts

# -------------------------------------------------------
# Environment files
# Keep .env.example so others can set up the project
# -------------------------------------------------------
.env
.env.local
.env.development
.env.test
.env.production
.env.staging

# Do NOT ignore the template/example files
!.env.example
!**/.env.example
!frontend/.env.template
!**/env.template

# -------------------------------------------------------
# Prisma
# -------------------------------------------------------
# Generated Prisma client (regenerated via `prisma generate`)
backend/prisma/generated/
backend/prisma/*.db
backend/prisma/*.db-journal

# -------------------------------------------------------
# Vite / Frontend cache
# -------------------------------------------------------
.vite/
**/.vite/
frontend/.vite/

# -------------------------------------------------------
# Logs
# -------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -------------------------------------------------------
# Test / Coverage
# -------------------------------------------------------
coverage/
**/coverage/
*.lcov
.nyc_output/

# -------------------------------------------------------
# Editor & IDE
# -------------------------------------------------------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# -------------------------------------------------------
# OS generated files
# -------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -------------------------------------------------------
# Docker runtime / volumes
# -------------------------------------------------------
.docker/
docker-data/

# -------------------------------------------------------
# Misc
# -------------------------------------------------------
*.tgz
*.zip
.cache/
**/.cache/